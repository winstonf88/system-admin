APP_NAME=Site Admin API
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=https://site1.com
APP_EXPOSE_DOCS=false
SECRET_KEY=change-me

# DigitalOcean Managed Database — use the connection string from the DO console
DATABASE_URL=postgresql+asyncpg://user:password@host:25060/dbname?ssl=require

# DigitalOcean Spaces
STORAGE_BACKEND=spaces
SPACES_KEY=your-spaces-access-key
SPACES_SECRET=your-spaces-secret-key
SPACES_REGION=nyc3
SPACES_BUCKET=your-bucket-name
SPACES_CDN_ENDPOINT=https://your-bucket.nyc3.cdn.digitaloceanspaces.com
