APP_NAME=system-admin API
APP_ENV=local
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:3000
APP_EXPOSE_DOCS=true
SECRET_KEY=change-me-in-production

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/system_admin
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Tenant scope is derived from the authenticated user (HTTP Basic: email + password).
# Clients must send Authorization: Basic ...; X-Tenant-ID is not used for authorization.

# Storage: "local" (default) or "spaces"
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=spaces
# SPACES_KEY=your-spaces-access-key
# SPACES_SECRET=your-spaces-secret-key
# SPACES_REGION=nyc3
# SPACES_BUCKET=your-bucket-name
# SPACES_CDN_ENDPOINT=https://your-bucket.nyc3.cdn.digitaloceanspaces.com
