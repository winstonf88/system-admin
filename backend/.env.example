APP_NAME=system-admin API
APP_ENV=local
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:3000
APP_EXPOSE_DOCS=true

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/system_admin
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

TENANT_RESOLUTION_STRATEGY=request_state_or_header
TENANT_HEADER_NAME=X-Tenant-ID
TENANT_STRICT_ENFORCEMENT=true
TENANT_BOOTSTRAP_ENABLED=true
TENANT_BOOTSTRAP_ID=1
TENANT_BOOTSTRAP_SLUG=default
TENANT_BOOTSTRAP_NAME=Default Tenant
